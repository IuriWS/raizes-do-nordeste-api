          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/promocoes", "host": ["{{baseUrl}}"], "path": ["promocoes"] }
          }
        }
      ]
    },
    {
      "name": "Auditoria",
      "item": [
        {
          "name": "T13 Cliente não consulta auditoria",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('status 403', () => pm.response.to.have.status(403));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auditoria", "host": ["{{baseUrl}}"], "path": ["auditoria"] }
          }
        }
